{
  "llm": {
    "provider_order": ["openrouter"],
    "openrouter": {
      "api_style": "openai",
      "base_url": "https://openrouter.ai/api",
      "api_key_env": "OPENROUTER_API_KEY",
      "model": "openai/gpt-5.2",
      "fallback_models": [
        "deepseek/deepseek-chat-v3-0324"
      ],
      "max_tokens": 8000,
      "temperature": 0.2
    }
  },
  "prompt_pack": {
    "parallel_frame_writer": {
      "enabled": false
    }
  },
  "tts": {
    "provider_order": ["edge_tts_wsl", "edge_tts"],
    "edge_tts_wsl": {
      "enabled": true,
      "wsl_exe": "wsl.exe",
      "edge_tts_cli": ".venv-linux/bin/edge-tts",
      "voice": "zh-CN-XiaoxiaoNeural",
      "rate": "+0%",
      "timeout_sec": 180
    },
    "edge_tts": {
      "voice": "zh-CN-XiaoxiaoNeural",
      "rate": "+0%"
    }
  },
  "image": {
    "auto_generate_enabled": false,
    "provider_order": ["openrouter_gemini_image", "pollinations", "local_placeholder"],
    "openrouter_gemini_image": {
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "model": "google/gemini-2.5-flash-image",
      "aspect_ratio": "16:9",
      "max_tokens": 2048,
      "retries": 3,
      "prompt_prefix": "Create a clean storyboard frame for a knowledge explainer video.",
      "prompt_suffix": "Prefer a teaching illustration, whiteboard-style explainer scene, or structured visual diagram instead of a poster, cover art, or promo image. No title cards, no readable text, no watermarks, no logos, no fake interface text. Do not turn metaphors into literal toys or mascots unless the prompt explicitly requires that."
    },
    "pollinations": {
      "width": 1280,
      "height": 720,
      "model": "flux",
      "seed": 42,
      "enhance": true,
      "nologo": true,
      "safe": true
    },
    "local_placeholder": {
      "width": 1280,
      "height": 720,
      "bg": [20, 30, 50],
      "fg": [230, 235, 245],
      "accent": [80, 150, 255]
    }
  },
  "video": {
    "width": 1280,
    "height": 720,
    "fps": 30,
    "audio_bitrate": "192k",
    "video_crf": 20,
    "min_segment_sec": 3.0,
    "subtitle_mode": "none",
    "segment_audio_padding_sec": 0.35
  },
  "layout": {
    "style": "storyboard_compact_label",
    "text_panel_width_ratio": 0.58,
    "panel_margin_left": 56,
    "panel_margin_top": 74,
    "panel_margin_bottom": 70,
    "title_font_size": 28,
    "body_font_size": 52,
    "body_line_height": 66,
    "body_line_spacing": 18,
    "accent_font_size": 20,
    "screen_text_max_chars_per_line": 14,
    "screen_text_max_lines": 2,
    "panel_hint_text": "",
    "bottom_text_height": 188,
    "compact_label_bottom_margin": 92
  }
}
