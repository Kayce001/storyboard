{
  "llm": {
    "provider_order": ["openrouter"],
    "openrouter": {
      "api_style": "openai",
      "base_url": "https://openrouter.ai/api",
      "api_key_env": "OPENROUTER_API_KEY",
      "model": "moonshotai/kimi-k2",
      "max_tokens": 4000,
      "temperature": 0.2
    }
  },
  "tts": {
    "provider_order": ["edge_tts", "pyttsx3", "gtts"],
    "edge_tts": {
      "voice": "zh-CN-XiaoxiaoNeural",
      "rate": "+0%"
    },
    "gtts": {
      "lang": "zh-cn",
      "tld": "com"
    },
    "pyttsx3": {
      "rate": 180,
      "voice_contains": "zh"
    }
  },
  "image": {
    "provider_order": ["pollinations", "local_placeholder"],
    "pollinations": {
      "width": 1280,
      "height": 720,
      "model": "flux",
      "seed": 42,
      "enhance": true,
      "nologo": true,
      "safe": true
    },
    "local_placeholder": {
      "width": 1280,
      "height": 720,
      "bg": [20, 30, 50],
      "fg": [230, 235, 245],
      "accent": [80, 150, 255]
    }
  },
  "video": {
    "width": 1280,
    "height": 720,
    "fps": 30,
    "audio_bitrate": "192k",
    "video_crf": 20,
    "min_segment_sec": 3.0,
    "subtitle_mode": "none"
  },
  "layout": {
    "style": "fullscreen_host_no_text",
    "host_background_image": "beijing.jpg",
    "text_panel_width_ratio": 0.58,
    "panel_margin_left": 56,
    "panel_margin_top": 74,
    "panel_margin_bottom": 70,
    "title_font_size": 28,
    "body_font_size": 52,
    "body_line_height": 66,
    "body_line_spacing": 18,
    "accent_font_size": 20,
    "screen_text_max_chars_per_line": 14,
    "screen_text_max_lines": 2,
    "panel_hint_text": "",
    "avatar_width_ratio": 0.30,
    "avatar_height_ratio": 0.82,
    "avatar_corner_radius": 36,
    "avatar_margin_right": 42,
    "avatar_float_px": 6,
    "center_avatar_width_ratio": 0.36,
    "center_avatar_height_ratio": 0.74,
    "avatar_top_margin": 24,
    "bottom_text_height": 188
  },
  "avatar": {
    "mode": "pipeline",
    "engine_order": ["musetalk", "liveportrait_then_musetalk", "static_image"],
    "engine_fallback": "static_image",
    "download_policy": {
      "retry_per_source": 2,
      "hf_endpoint_fallback": "https://hf-mirror.com"
    },
    "liveportrait": {
      "enabled": true,
      "repo_dir": "third_party/LivePortrait/LivePortrait-main/LivePortrait-main",
      "python_executable": ".venv/Scripts/python.exe",
      "driving_path": "third_party/LivePortrait/LivePortrait-main/LivePortrait-main/assets/examples/driving/d0.mp4",
      "output_subdir": "liveportrait",
      "extra_args": [
        "--driving_multiplier",
        "1.0",
        "--animation_region",
        "all"
      ]
    },
    "musetalk": {
      "enabled": true,
      "repo_dir": "third_party/MuseTalk",
      "python_executable": ".venv-musetalk/Scripts/python.exe",
      "output_subdir": "musetalk",
      "version": "v15",
      "ffmpeg_path": ".venv/Scripts",
      "batch_size": 4,
      "fps": 25,
      "use_float16": true,
      "inference_config": "",
      "unet_model_path": "",
      "unet_config_path": "",
      "whisper_dir": ""
    }
  }
}
